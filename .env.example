# --- Database (Supabase Postgres) ---
# Supabase → Connect → ORMs → Prisma gives both strings, pre-filled.
# DATABASE_URL: pooled "Transaction" connection (port 6543) used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) used for `prisma migrate`.
DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

# Note: the app talks to Supabase purely through Prisma (the connection strings
# above), so the supabase-js browser client vars (NEXT_PUBLIC_SUPABASE_URL /
# NEXT_PUBLIC_SUPABASE_ANON_KEY) are not needed and intentionally omitted.

# --- Spotify ---
# Spotify Developer Dashboard → your app → Settings.
# The client id stays server-side (the browser playback SDK uses a short-lived
# access token from /api/spotify/token), so no NEXT_PUBLIC_ copy is needed.
SPOTIFY_CLIENT_ID=""
# Used by catalog search on the "add a record" page (client-credentials flow).
# Not used by the PKCE playback login — but search needs it, so set it.
SPOTIFY_CLIENT_SECRET=""
# Must byte-match a Redirect URI registered in the dashboard. Spotify now
# requires the explicit loopback IP for local dev (127.0.0.1, not localhost).
SPOTIFY_REDIRECT_URI="http://127.0.0.1:3000/api/spotify/callback"
